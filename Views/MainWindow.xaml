<Window x:Class="TelegramProxy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Telegram Bridge Core" Height="700" Width="850" Background="#121212" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.5*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Margin="0,0,0,15" Padding="15" Background="#1E1E1E" CornerRadius="8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="16" Height="16" Fill="{Binding StatusColor}" Margin="0,0,15,0"/>
                <TextBlock Text="Proxy Gateway" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" Margin="0,0,30,0"/>
                
                <Button Content="Initialize Bridge" Command="{Binding StartCommand}" Width="110" Height="28" Margin="0,0,10,0" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Terminate" Command="{Binding StopCommand}" Width="90" Height="28" Margin="0,0,30,0" Background="#D13438" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                
                <TextBlock Text="Connection URL:" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                <TextBox Text="{Binding ConnectionLink}" IsReadOnly="True" BorderThickness="0" Background="#252526" Foreground="#4EC9B0" VerticalAlignment="Center" Padding="5" FontSize="14" Width="280" />
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1" Margin="0,0,0,15" Padding="15" Background="#1E1E1E" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Endpoint Pipeline Setup" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15" Foreground="#EEEEEE"/>
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Vertical" Margin="0,0,25,0">
                        <TextBlock Text="Local Port" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SettingsVM.LocalPort}" Width="80" Height="26" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="0,0,25,0">
                        <TextBlock Text="Target Relay Node" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding SettingsVM.Datacenters}" SelectedItem="{Binding SettingsVM.SelectedDc}" DisplayMemberPath="Name" Width="140" Height="26" Background="#2D2D30" Foreground="White"/>
                    </StackPanel>
                    <CheckBox Content="Route via Cloudflare Tunnel" IsChecked="{Binding SettingsVM.UseCloudflare}" Foreground="White" VerticalAlignment="Center" Margin="0,0,25,0"/>
                    <Button Content="Save Setup" Command="{Binding SettingsVM.SaveCommand}" Width="100" Height="26" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand" VerticalAlignment="Bottom"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2" Margin="0,0,0,15" Background="#1E1E1E" CornerRadius="8" Padding="10">
            <lvc:CartesianChart Series="{Binding Series}"/>
        </Border>
        
        <Border Grid.Row="3" Background="#1A1A1A" CornerRadius="8" Padding="10">
            <ListView ItemsSource="{Binding Logs}" Background="Transparent" Foreground="#D4D4D4" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Window>
